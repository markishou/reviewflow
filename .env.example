# ==============================================
# ReviewFlow Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ==============================================

# --- Neon Database ---
# Get this from your Neon console → project → connection string
# Uses the -pooler endpoint for Lambda compatibility (PgBouncer)
DATABASE_URL=postgresql://user:password@ep-xxxxx-pooler.us-east-2.aws.neon.tech/reviewflow?sslmode=require&channel_binding=require

# --- AWS Configuration ---
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# --- AWS Cognito (from Sprint 0) ---
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# --- AWS API Gateway ---
API_GATEWAY_ID=xxxxxxxxxx
API_GATEWAY_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod

# --- AWS Secrets Manager ---
# Name of the secret storing the Neon connection string
NEON_SECRET_NAME=reviewflow/neon-connection-string

# --- GitHub OAuth (Sprint 1 — set up when we create the OAuth App) ---
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
GITHUB_WEBHOOK_SECRET=your_webhook_secret_for_signature_validation

# --- Application ---
APP_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000
